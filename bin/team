#!/usr/bin/env bash
# Launchable `team` CLI: run the TypeScript entrypoint under tsx.
# Kept separate from bin/team.ts so the .ts file stays shebang-free and loadable
# as a module (a shebang breaks tsx's parser).
set -euo pipefail
# Resolve this script through any chain of symlinks (e.g. `npm link` / `npm i -g`
# put a symlink in the global bin dir) so DIR points at the real bin/ in the
# clone, NOT the symlink's directory. Portable POSIX loop: no `readlink -f` /
# `realpath`, which are absent on stock macOS.
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  # A relative symlink target resolves against the symlink's own directory.
  case "$SOURCE" in
    /*) ;;
    *) SOURCE="$DIR/$SOURCE" ;;
  esac
done
DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
# Launch via the framework's LOCAL tsx bin (not `node --import tsx`): node would
# resolve the bare `tsx` specifier from the user's cwd, breaking when `team` runs
# from any directory outside this clone. The user's cwd is preserved for relative
# TEAM_CONFIG; team.ts's ../src imports resolve relative to team.ts.
exec "$DIR/../node_modules/.bin/tsx" "$DIR/team.ts" "$@"
